{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build: vendored libbpf",
      "type": "shell",
      "command": "cd third_party/libbpf/src && make BUILD_STATIC_ONLY=1 OBJDIR=${workspaceFolder}/build/libbpf && make BUILD_STATIC_ONLY=1 OBJDIR=${workspaceFolder}/build/libbpf DESTDIR=${workspaceFolder}/build/libbpf PREFIX='' install",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "CMake: Configure (Debug)",
      "type": "shell",
      "command": "cmake -B build -S . -DCMAKE_BUILD_TYPE=Debug -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "dependsOn": ["Build: vendored libbpf"],
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "CMake: Configure (Release)",
      "type": "shell",
      "command": "cmake -B build -S . -DCMAKE_BUILD_TYPE=Release -DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "dependsOn": ["Build: vendored libbpf"],
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build All",
      "type": "shell",
      "command": "cmake --build build -j$(nproc)",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "CMake: Build uatu CLI",
      "type": "shell",
      "command": "cmake --build build --target uatu -j$(nproc)",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Test: Unit Tests",
      "type": "shell",
      "command": "./build/tests/unit/test_symbol_finder && ./build/tests/unit/test_json_codec",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Test: Integration (no root)",
      "type": "shell",
      "command": "./build/tests/integration/test_watch && ./build/tests/integration/test_trace && ./build/tests/integration/test_stack",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Test: All (ctest)",
      "type": "shell",
      "command": "ctest --test-dir build --output-on-failure",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Run: target_debug fixture",
      "type": "shell",
      "command": "./build/tests/fixtures/target_debug",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "CMake: Clean",
      "type": "shell",
      "command": "cmake --build build --target clean",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "none",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
